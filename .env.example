# Zkopíruj na `.env` a uprav. `.env` je gitignored.

# --- Caddy / doména ---
DOMAIN=localhost
HTTP_PORT=80
HTTPS_PORT=443

# --- Produkce (docker-compose.prod.yml) ---
# Který image tag táhnout z GHCR (Watchtower hlídá :latest).
IMAGE_TAG=latest

# --- Postgres ---
POSTGRES_USER=game
POSTGRES_PASSWORD=game
POSTGRES_DB=game

# --- API (lokální dev mimo docker) ---
PORT=3000
DATABASE_URL=postgres://game:game@localhost:5432/game
REDIS_URL=redis://localhost:6379

# --- Auth (JWT) — v produkci NASTAV vlastní silný JWT_SECRET! ---
JWT_SECRET=dev-insecure-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# --- Web Push (VAPID) — doplní se v M3 ---
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Zkopíruj na `.env` a uprav. `.env` je gitignored.

# --- Caddy / doména (lokální dev přes docker-compose.yml) ---
# V produkci (docker-compose.prod.yml) Caddy hostové porty NEpublikuje — provoz jde
# přes Cloudflare Tunnel. HTTP_PORT/HTTPS_PORT se uplatní jen v lokálním dev compose.
DOMAIN=localhost
HTTP_PORT=80
HTTPS_PORT=443

# --- Produkce (docker-compose.prod.yml) ---
# Který image tag táhnout z GHCR (Watchtower hlídá :latest).
IMAGE_TAG=latest

# Caddy v produkci poslouchá interně na HTTP :80 (HTTPS řeší Cloudflare na edge).
# DOMAIN=:80

# Cloudflare Tunnel — POVINNÉ pro produkci (cloudflared běží vždy a bez tokenu
# se stack nespustí). Token z Cloudflare Zero Trust.
# Viz docs/DEPLOY.md → „Krok 2 — Vytvořit Cloudflare Tunnel".
# TUNNEL_TOKEN=

# --- Postgres ---
POSTGRES_USER=game
POSTGRES_PASSWORD=game
POSTGRES_DB=game

# --- API (lokální dev mimo docker) ---
PORT=3000
DATABASE_URL=postgres://game:game@localhost:5432/game
REDIS_URL=redis://localhost:6379

# --- Auth (JWT) — v produkci NASTAV vlastní silný JWT_SECRET! ---
JWT_SECRET=dev-insecure-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# --- Web Push (VAPID) — doplní se v M3 ---
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
